# =====================================================================
# .gitignore - Sistema de Gestao de Patio Sambaiba
# =====================================================================
# Vale pra raiz do repo. Ha .gitignore especificos em subpastas
# (ex.: backend/.gitignore) que cuidam do que e especifico de cada stack.
# =====================================================================

# --- Ferramentas / Cowork / Claude Code ---
.claude/

# --- Editores e IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- Logs ---
*.log
logs/

# --- Planilhas e CSVs locais (dados de teste) ---
# Pra commitar uma planilha especifica: git add -f caminho/da/planilha.xlsx
*.xlsx
*.xls
*.csv

# --- Arquivos temporarios ---
*.tmp
*.bak
*.old

# Pasta de contexto privado entre sessoes do Claude (Cowork + Claude Code) - fora do versionamento
_handoff-claude/
