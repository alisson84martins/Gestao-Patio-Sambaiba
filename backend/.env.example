# =====================================================================
# Configuração do Backend — Gestão de Pátio Sambaíba v3.0
# =====================================================================
# Copie este arquivo para `.env` e ajuste os valores para seu ambiente.
# NUNCA commite o `.env` real (ele está no .gitignore).
# =====================================================================

# --- Banco de dados ---
# Formato: postgresql+psycopg://USUARIO:SENHA@HOST:PORTA/BANCO
# Local (desenvolvimento):
DATABASE_URL=postgresql+psycopg://postgres:SUA_SENHA_AQUI@localhost:5432/gestao_patio_sambaiba

# --- Segurança ---
# Chave secreta para assinar os tokens JWT.
# Gere uma forte com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=mude-isto-em-producao-com-uma-string-aleatoria-longa-e-segura
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Ambiente ---
# development | staging | production
ENVIRONMENT=development

# --- CORS ---
# Origens permitidas separadas por vírgula. Em produção, restrinja!
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500,https://alisson84martins.github.io

# --- Logs ---
LOG_LEVEL=INFO
